rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Allow public read access to 'assets' folder
    match /assets/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow public read access to 'images' folder
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Restrict access to 'exports' folder to authenticated users
    match /exports/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    match /userImages/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /tempUploads/{allPaths=**} {
      allow write: if request.auth != null;  // authenticated users only
      allow read: if true;                   // Vision API can access via public URL
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
